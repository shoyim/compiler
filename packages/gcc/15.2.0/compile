#!/usr/bin/env bash
set -e

case "${COMPILER_LANGUAGE}" in
    c)
        for f in "$@"; do
            [[ "$f" == *.c ]] || mv "$f" "${f%.*}.c"
        done
        gcc -O2 -std=c11 *.c -lm -o a.out
        ;;
    c++)
        for f in "$@"; do
            [[ "$f" == *.cpp ]] || mv "$f" "${f%.*}.cpp"
        done
        g++ -O2 -std=c++20 *.cpp -lm -o a.out
        ;;
    d)
        for f in "$@"; do
            [[ "$f" == *.d ]] || mv "$f" "${f%.*}.d"
        done
        gdc *.d -o a.out
        ;;
    fortran)
        for f in "$@"; do
            [[ "$f" == *.f90 ]] || [[ "$f" == *.f ]] || mv "$f" "${f%.*}.f90"
        done
        gfortran *.f90 -o a.out
        ;;
    *)
        echo "Unknown language: ${COMPILER_LANGUAGE}" >&2
        exit 1
        ;;
esac

chmod +x a.out
